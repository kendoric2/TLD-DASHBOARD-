{
  "_meta": {
    "description": "JSON request bodies for TLDCRM read-only egress queries. Sent as POST with Content-Type: application/json. PULL ONLY — nothing is written back.",
    "date_rule": "Date filtering = set the date column to a TLD relative label in the body, e.g. {\"date_sold\": \"This Month\"}. The client injects <date_field> = <label> for date_bounded queries.",
    "notes": "columns is a JSON array; sort direction is 'sort' (ASC|DESC). Matches the working payload shape from TLD."
  },
  "queries": {
    "policies_count": {
      "endpoint": "policies",
      "date_bounded": true,
      "date_field": "date_sold",
      "payload": { "aggregates": true, "aggregate": true, "columns": ["tql_cnt_policy_id"] }
    },

    "billable_leads_count": {
      "endpoint": "leads",
      "date_bounded": true,
      "date_field": "date_created",
      "payload": { "billable": 1, "aggregates": true, "aggregate": true, "columns": ["tql_cnt_lead_id"] }
    },

    "avg_gtl_premium": {
      "endpoint": "policies",
      "date_bounded": true,
      "date_field": "date_sold",
      "payload": { "carrier": "GTL", "aggregates": true, "aggregate": true, "columns": ["tql_avg_premium"] }
    },

    "policies_by_carrier": {
      "endpoint": "policies",
      "date_bounded": true,
      "date_field": "date_sold",
      "label_field": "carrier_name",
      "payload": { "aggregates": true, "group_by": "carrier_name", "columns": ["carrier_name", "tql_cnt_policy_id"], "order_by": "tql_cnt_policy_id", "sort": "DESC" }
    },

    "policies_by_plan": {
      "endpoint": "policies",
      "date_bounded": true,
      "date_field": "date_sold",
      "label_field": "product",
      "payload": { "aggregates": true, "group_by": "product", "columns": ["product", "tql_cnt_policy_id"], "order_by": "tql_cnt_policy_id", "sort": "DESC" }
    },

    "recent_sales": {
      "endpoint": "policies",
      "date_bounded": false,
      "payload": { "sold": 1, "columns": ["date_sold", "agent_name", "product", "carrier_name", "premium", "status"], "order_by": "date_sold", "sort": "DESC", "limit": 12 }
    },

    "agent_policies": {
      "endpoint": "policies",
      "date_bounded": true,
      "date_field": "date_sold",
      "payload": { "aggregates": true, "group_by": "agent_name", "columns": ["agent_name", "tql_cnt_policy_id", "tql_cnu_lead_id"], "order_by": "tql_cnt_policy_id", "sort": "DESC", "limit": 15 }
    }
  }
}
