{
  "_meta": {
    "description": "JSON request bodies for TLDCRM read-only egress queries. Sent as GET requests with a JSON body (Content-Type: application/json). PULL ONLY — nothing is written back.",
    "date_rule": "Date filtering uses explicit M/D/YYYY ranges, not relative labels. For date_bounded queries the client sets <date_field> + <date_field>_end to the resolved range; when date_field is date_sold it also adds start_date + end_date (the reliable dual). See tldcrm_client._payload().",
    "notes": "columns is a JSON array; sort direction is 'sort' (ASC|DESC). Matches the working payload shape from TLD."
  },
  "queries": {
    "policies_count": {
      "endpoint": "policies",
      "date_bounded": true,
      "date_field": "date_sold",
      "payload": { "aggregates": true, "aggregate": true, "columns": ["tql_cnt_policy_id"] }
    },

    "billable_leads_count": {
      "endpoint": "leads",
      "date_bounded": true,
      "date_field": "date_created",
      "payload": { "vendor_id": 14646, "billable": 1, "aggregates": true, "aggregate": true, "columns": ["tql_cnt_lead_id"] }
    },

    "falcon_billable_status": {
      "endpoint": "leads",
      "date_bounded": true,
      "date_field": "date_created",
      "payload": { "vendor_id": 14646, "billable": 1, "aggregates": true, "group_by": "status_name", "columns": ["status_name", "tql_cnt_lead_id"], "order_by": "tql_cnt_lead_id", "sort": "DESC", "limit": 100 }
    },

    "avg_gtl_premium": {
      "endpoint": "policies",
      "date_bounded": true,
      "date_field": "date_sold",
      "payload": { "carrier": "GTL", "aggregates": true, "aggregate": true, "columns": ["tql_avg_premium"] }
    },

    "policies_by_carrier": {
      "endpoint": "policies",
      "date_bounded": true,
      "date_field": "date_sold",
      "label_field": "carrier_name",
      "payload": { "aggregates": true, "group_by": "carrier_name", "columns": ["carrier_name", "tql_cnt_policy_id"], "order_by": "tql_cnt_policy_id", "sort": "DESC" }
    },

    "policies_by_plan": {
      "endpoint": "policies",
      "date_bounded": true,
      "date_field": "date_sold",
      "label_field": "product",
      "payload": { "aggregates": true, "group_by": "product", "columns": ["product", "tql_cnt_policy_id"], "order_by": "tql_cnt_policy_id", "sort": "DESC" }
    },

    "recent_sales": {
      "endpoint": "policies",
      "date_bounded": false,
      "payload": { "sold": 1, "columns": ["date_sold", "agent_name", "product", "carrier_name", "premium", "status"], "order_by": "date_sold", "sort": "DESC", "limit": 12 }
    },

    "agent_policies": {
      "endpoint": "policies",
      "date_bounded": true,
      "date_field": "date_sold",
      "payload": { "aggregates": true, "group_by": "agent_name", "columns": ["agent_name", "tql_cnt_policy_id", "tql_cnu_lead_id"], "order_by": "tql_cnt_policy_id", "sort": "DESC", "limit": 15 }
    }
  }
}
