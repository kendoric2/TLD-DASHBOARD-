.env

# Local data / probe output (may contain customer PII) — never commit
policy_*.txt
*.local.json
*.xlsx
egress_columns.xlsx

# Internal blueprint / docs — kept locally, not committed
docs/

# Logs / metrics — local operational data, not committed
logs/

# Python
__pycache__/
*.pyc
.venv/
venv/
env/

# OS / editor
.DS_Store
*.log

# Local push helper — keep on disk, but out of the repo
push_to_github.command
